@page
@model ToolDrawingProcessor.Pages.Database.IndexModel
@{
    ViewData["Title"] = "Tool Database";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">
        <i class="bi bi-database me-2"></i>Master Tool Database
    </h4>
    <div>
        <a asp-page-handler="ExportExcel" class="btn btn-success btn-sm">
            <i class="bi bi-file-earmark-spreadsheet me-1"></i>Export to Excel
        </a>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-info alert-dismissible fade show">
        @Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        @if (Model.Specs.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover table-sm mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Source File</th>
                            <th>Tool Type</th>
                            <th>Dia (mm)</th>
                            <th>Flute L (mm)</th>
                            <th>Corner R (mm)</th>
                            <th>Shank D (mm)</th>
                            <th>Total L (mm)</th>
                            <th>Flutes</th>
                            <th>Confidence</th>
                            <th>Corrections</th>
                            <th>Provider</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var spec in Model.Specs)
                        {
                            var corrClass = spec.CorrectionCount == 0 ? "text-success" :
                                            spec.CorrectionCount <= 2 ? "text-warning" : "text-danger";
                            var confClass = spec.OverallConfidence >= 0.85 ? "bg-success" :
                                            spec.OverallConfidence >= 0.6 ? "bg-warning text-dark" : "bg-danger";
                            <tr>
                                <td>@spec.Id</td>
                                <td class="small">@spec.SourceFileName</td>
                                <td><span class="badge bg-info text-dark">@spec.ToolType</span></td>
                                <td>@spec.Diameter?.ToString("F2")</td>
                                <td>@spec.FluteLength?.ToString("F2")</td>
                                <td>@spec.CornerRadius?.ToString("F2")</td>
                                <td>@spec.ShankDiameter?.ToString("F2")</td>
                                <td>@spec.TotalLength?.ToString("F2")</td>
                                <td>@spec.NumberOfFlutes</td>
                                <td>
                                    <span class="badge @confClass">
                                        @spec.OverallConfidence.ToString("P0")
                                    </span>
                                </td>
                                <td>
                                    <span class="fw-bold @corrClass">
                                        @if (spec.CorrectionCount == 0)
                                        {
                                            <i class="bi bi-check-circle"></i>
                                        }
                                        else
                                        {
                                            @spec.CorrectionCount
                                        }
                                    </span>
                                </td>
                                <td class="small text-muted">@spec.AIProviderUsed/@spec.ModelUsed</td>
                                <td>
                                    <a asp-page="/Review/Index" asp-route-id="@spec.UploadedFileId"
                                       class="btn btn-sm btn-outline-primary" title="Review">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-database-x display-1 d-block mb-3"></i>
                <p>No tool specifications yet. Process some drawings first.</p>
            </div>
        }
    </div>
</div>

<!-- Legend -->
<div class="card shadow-sm mt-3">
    <div class="card-body py-2">
        <small class="text-muted">
            <strong>Corrections Legend:</strong>
            <span class="text-success me-3"><i class="bi bi-check-circle"></i> No corrections</span>
            <span class="text-warning me-3"><i class="bi bi-circle-fill"></i> 1-2 corrections</span>
            <span class="text-danger"><i class="bi bi-circle-fill"></i> 3+ corrections</span>
        </small>
    </div>
</div>
